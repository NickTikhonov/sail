{
  "name": "sail",
  "version": "0.1.0",
  "private": false,
  "description": "Agent-first TypeScript IDE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NickTikhonov/sail.git"
  },
  "bugs": {
    "url": "https://github.com/NickTikhonov/sail/issues"
  },
  "homepage": "https://github.com/NickTikhonov/sail#readme",
  "bin": {
    "sail": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs/sail-help-preamble.txt"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "dev:link": "pnpm run build && pnpm link --global",
    "prepack": "pnpm run build",
    "test": "pnpm build && node --test ./test/*.test.js"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "diff": "^8.0.2",
    "ts-morph": "^25.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
